# Biconomy MEE Configuration (Fusion Mode)
# Get your keys from: https://dashboard.biconomy.io/
BICONOMY_API_KEY=mee_4tDgt6JRovzz33xioQ3m2r
BICONOMY_BUNDLER_URL=https://bundler.biconomy.io/api/v2/80002/YOUR_BUNDLER_KEY_HERE
BICONOMY_PAYMASTER_URL=https://paymaster.biconomy.io/api/v1/80002/YOUR_PAYMASTER_KEY_HERE

# MEE Fusion Mode: Users pay gas with ERC-20 tokens (NO MATIC needed!)
# Fusion works with: MetaMask, Trust Wallet, Rabby, and other external wallets

# Network Configuration (Polygon Amoy Testnet)
CHAIN_ID=80002
RPC_URL=https://rpc-amoy.polygon.technology/

# Server Configuration
PORT=3000
NODE_ENV=development

# Security
API_SECRET_KEY=your-secure-random-string-change-this
ALLOWED_ORIGINS=http://localhost:*,https://yourdomain.com

# Backend Wallet - CRITICAL! This wallet sponsors gas for users
# Generate: node -e "console.log(require('ethers').Wallet.createRandom().privateKey)"
SERVER_PRIVATE_KEY=your_backend_wallet_private_key_here

# Authentication: Wallet-Based (No Firebase Required!)
# Users are authenticated by their wallet address
# Optional: Can require signature verification for added security

# Token Contracts (Polygon Amoy)
AKOFA_TOKEN_ADDRESS=0xf1266ACCf0f757c61e4DFDD9EBBcaC05D2Ee375F
USDC_TOKEN_ADDRESS=0x41E94Eb019C0762f9Bfcf9Fb1E58725BfB0e7582

# M-Pesa Daraja 3.0 (Backend)
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your_sandbox_consumer_key
MPESA_CONSUMER_SECRET=your_sandbox_consumer_secret
MPESA_PASSKEY=your_sandbox_passkey
MPESA_SHORTCODE=174379
MPESA_CALLBACK_URL=https://azix-flutter.vercel.app/api/mpesa/callback
MPESA_C2B_SHORTCODE=174379
MPESA_C2B_RESPONSE_TYPE=Completed
MPESA_C2B_CONFIRMATION_URL=https://azix-flutter.vercel.app/api/mpesa/c2b/confirmation
MPESA_C2B_VALIDATION_URL=https://azix-flutter.vercel.app/api/mpesa/c2b/validation
MPESA_INITIATOR_NAME=your_b2b_initiator_username
MPESA_SECURITY_CREDENTIAL=your_encrypted_initiator_password
MPESA_B2B_QUEUE_URL=https://azix-flutter.vercel.app/api/mpesa/b2b/queue
MPESA_B2B_RESULT_URL=https://azix-flutter.vercel.app/api/mpesa/b2b/result

# PesaPal Card Payment API 3.0
# Get credentials from: https://developer.pesapal.com
# Register for a business account, then get Consumer Key and Secret
PESAPAL_ENV=sandbox
PESAPAL_CONSUMER_KEY=your_pesapal_consumer_key
PESAPAL_CONSUMER_SECRET=your_pesapal_consumer_secret
# IPN ID is obtained after registering your IPN URL via POST /api/pesapal/register-ipn
PESAPAL_IPN_ID=your_pesapal_ipn_id
# Callback URL - where users are redirected after payment
PESAPAL_CALLBACK_URL=https://azix-flutter.vercel.app/api/pesapal/callback
# IPN URL - receives real-time payment notifications
PESAPAL_IPN_URL=https://azix-flutter.vercel.app/api/pesapal/ipn-callback

# MoonPay Onramp Configuration
# Get your keys from: https://dashboard.moonpay.com/
MOONPAY_API_KEY=pk_live_xxxxxxxxx
# Webhook secret (OPTIONAL - webhook works without it but signature verification will be disabled)
# Only set this if you want to receive and verify MoonPay webhooks
# MOONPAY_WEBHOOK_SECRET=whsec_xxxxxxxxx
# Return URL after MoonPay checkout completes
APP_RETURN_URL=myapp://moonpay-return
# Note: MoonPay webhook is OPTIONAL - MoonPay sends tokens directly on-chain
# The webhook is only for transaction record-keeping in Firestore (optional)
# Firebase configuration is shared with other services (see firebase-service-account.json or FIREBASE_SERVICE_ACCOUNT env var)

